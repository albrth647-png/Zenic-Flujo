# ═══════════════════════════════════════════════════════════
# Zenic-Flijo — Environment Variables
# Task IDs: 0-4, 0-7, 0-8
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────
# Production mode: enables strict secret validation
WFD_PRODUCTION=false

# Data directory for SQLite DB, backups, and file storage
WFD_DATA_DIR=~/.workflow_determinista

# ── Security (REQUIRED in production) ─────────────────────
# Session secret: minimum 64 characters, random in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
WFD_SESSION_SECRET=

# License HMAC key: minimum 64 characters, random in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
WFD_LICENSE_SECRET=

# Enable secure cookies (required for HTTPS in production)
WFD_SESSION_SECURE=false

# ── Web Server ────────────────────────────────────────────
# Host to bind the web server (0.0.0.0 for Docker, 127.0.0.1 for local)
WFD_WEB_HOST=127.0.0.1

# Web UI and API port
WFD_WEB_PORT=8080

# Webhook receiver port
WFD_WEBHOOK_PORT=8081

# ── Logging ───────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
WFD_LOG_LEVEL=INFO

# ── PostgreSQL (docker-compose) ───────────────────────────
# PostgreSQL connection URL (set automatically by docker-compose)
WFD_POSTGRES_URL=postgresql://zenic:zenic_dev@localhost:5432/zenic_flijo

# PostgreSQL container settings
POSTGRES_USER=zenic
POSTGRES_PASSWORD=zenic_dev
POSTGRES_DB=zenic_flijo
POSTGRES_PORT=5432

# ── MongoDB (optional, for document storage) ──────────────
WFD_MONGODB_URI=mongodb://localhost:27017
WFD_MONGODB_DB=zenic_flijo

# ── Redis (docker-compose) ────────────────────────────────
# Redis URL for cache, sessions, and Pub/Sub event bus
WFD_REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ── Ollama (AI Enhancement) ───────────────────────────────
WFD_OLLAMA_ENABLED=false
WFD_OLLAMA_URL=http://localhost:11434
WFD_OLLAMA_MODEL=llama3.2
WFD_OLLAMA_TIMEOUT=30

# ── OpenAI Integration ────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Stripe Integration ────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=

# ── MercadoPago Integration ──────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=

# ── Google Integrations ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/integrations/google/callback

# ── Slack Integration ────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Telegram Integration ─────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Gmail Integration ────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── SSO / SAML (Phase 1) ─────────────────────────────────
SAML_IDP_METADATA_URL=
SAML_SP_ENTITY_ID=
SAML_SP_ACS_URL=
SAML_SP_SLS_URL=
SAML_SP_X509_CERT=
SAML_SP_PRIVATE_KEY=

# ── SSO / OIDC (Phase 1) ─────────────────────────────────
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=
OIDC_REDIRECT_URI=http://localhost:8080/api/auth/oidc/callback

# ── Observability (Phase 1) ──────────────────────────────
OTEL_EXPORTER_PROMETHEUS_PORT=9464
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_SERVICE_NAME=zenic-flijo
