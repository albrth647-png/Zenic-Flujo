  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["application/pdf", "image/*", "text/csv", "application/json"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+zenic",
      "url": "/handle?url=%s"
    }
  ]
